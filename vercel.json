{
  "rewrites": [
    { "source": "/brands/verismart", "destination": "/brands/verismart/index.html" },
    { "source": "/brands/verismart/(.*)", "destination": "/brands/verismart/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
